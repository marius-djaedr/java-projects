<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="info" name="dungeonworld" packages="">
  <Appenders>
  	<Console name="STDOUT" >
      <PatternLayout pattern="%d %-5p %-16t [%C] - %m%n"/>
    </Console>    
    <RollingFile name="FILE" filePattern="c://programs/dungeonworld/logs/%d{yyyy-MM-dd}.%i.log"> 
      <PatternLayout pattern="%d %-5p %-16t [%C] - %m%n"/>
	  <Policies>
	    <OnStartupTriggeringPolicy/>
	  </Policies>
    </RollingFile>
  </Appenders>
  <Loggers>
    <Root level="info">
      <AppenderRef ref="STDOUT"/>
      <AppenderRef ref="FILE"/>
    </Root>
  </Loggers>
</Configuration>